---
import Header from '../components/Header.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import WorkRow from '../components/WorkRow.astro';
import { getWall } from '../lib/works';

const works = await getWall();
---

<BaseLayout
  title="Ryodgie Barnatia — Creative Designer & Developer"
  description="Ryodgie Barnatia — web designer and front-end developer (Vue, React, Astro). Portfolio of live coded websites, editorial, motion, and design experiments."
>
  <main class="wall">
     <Header />
    {works.map((work, i) => <WorkRow work={work} index={i} />)}
  </main>
</BaseLayout>