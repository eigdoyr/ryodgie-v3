---
import { Picture } from 'astro:assets';
import Caption from './Caption.astro';
import type { Work } from '../lib/works';

interface Props { work: Work; index: number }
const { work, index } = Astro.props;
const { images } = work.data;

const weights = images.map((img) => img.weight);
const total = weights.reduce((a, b) => a + b, 0);
---
<article class="work">
    <a class="row-link" href={`/work/${work.id}`}>
  <div class="row">
    {images.map((img, i) => {
      const fraction = weights[i] / total;
        const sizes = `(max-width: 639px) 100vw, (max-width: 1024px) 50vw, (max-width: 1548px) ${(fraction * 100).toFixed(1)}vw, ${Math.round(fraction * 1500)}px`;
     return (
        <figure style={`--ar: ${img.src.width}/${img.src.height}; --grow: ${img.weight};`}>         
        <Picture
            src={img.src}
            alt={img.alt}
            formats={['avif', 'webp']}
            widths={[640, 960, 1280]}
            sizes={sizes}
            loading={index === 0 ? 'eager' : 'lazy'}
          />
        </figure>
      );
    })}
  </div>
  </a>
  <Caption work={work} />
</article>

